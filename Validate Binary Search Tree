class Solution {
    bool solve(TreeNode* root, long min,long max){
        if(root==nullptr)
        return true;
        if(root->val >=max || root->val <= min)
        return false;
        return solve(root-> left, min, root->val) && solve(root->right,root->val,max);
    } 
public:
    bool isValidBST(TreeNode* root) {
        return solve(root, LONG_MIN, LONG_MAX);
    }
};
