class Solution {
public:
    int minEatingSpeed(vector<int>& arr, int h) {
        int low=1; 
        int high=*max_element(arr.begin(),arr.end());
        while(low<high){
            int mid= low+(high-low)/2;
            int k=0;
            for(int &i:arr){
                k += (int)ceil((double)i/mid);
            }
            if(k<=h){
                high=mid;
                }
                else
                low=mid+1;
        }
return low;
    }
};
