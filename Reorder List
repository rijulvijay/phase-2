class Solution {
ListNode* midNode(ListNode* head) {
ListNode *slow=head,*fast=head;
while(fast->next!=nullptr && fast->next->next!=nullptr) {slow = slow->next;
fast = fast->next->next;
}
return slow;
}
public:
void reorderList(ListNode* head) {
if(head->next==nullptr || head->next->next==nullptr)
return;
ListNode* mid = midNode(head);
ListNode* ptr = mid->next;
mid->next = nullptr;
stack<ListNode*> stk;
while(ptr) {
stk.push(ptr);
ptr = ptr->next;
}
ptr = head;
while(!stk.empty()){
ListNode* temp = stk.top();
stk.pop();
temp->next = ptr->next;
ptr->next = temp;
ptr = ptr->next->next;
}
}
};
