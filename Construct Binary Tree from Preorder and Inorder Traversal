class Solution {
    TreeNode* treeMake(unordered_map<int,int> &map, vector<int>& inorder, int inSt, int inEnd,vector<int> &preorder, int preSt, int preEnd){
        if(inSt > inEnd || preSt > preEnd)
        return nullptr;
        TreeNode *root= new TreeNode(preorder[preSt]);
        int rootIndex= map[root->val];
        int leftSize= rootIndex-inSt;
        root->left=treeMake(map,inorder, inSt, rootIndex - 1, preorder, preSt + 1, preSt + leftSize);
        root->right=treeMake(map,inorder, rootIndex + 1, inEnd, preorder, preSt + leftSize + 1, preEnd);
        return root;
    } 

public:
    TreeNode* buildTree(vector<int>& preorder, vector<int>& inorder) {
        unordered_map<int,int> map;
        for (int i = 0; i < inorder.size(); i++)
            map[inorder[i]] = i;
        return treeMake(map, inorder, 0, inorder.size() - 1, preorder, 0, preorder.size() - 1);
    }
};
