class Solution {
public:
int trap(vector<int>& arr) {
int n = arr.size();
vector<int> left(n,0),right(n,0);
//left max
for(int i=1 ; i<n ; i++) {
left[i] = max(left[i-1],arr[i-1]);
}
//right max
for(int i=n-2 ; i>=0 ; i--) {
right[i] = max(arr[i+1],right[i+1]);
}
int count=0;
for(int i=1 ; i<n-1 ; i++) {
if(left[i]>arr[i] && right[i]>arr[i]) {
count += min(left[i],right[i])-arr[i];
}
}
return count;
}
};
